<% layout("/layouts/boilerplate") %>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h1 class="fw-bold">📊 AssetFlow Dashboard</h1>
        <p class="text-muted">
            Manage assets, departments and categories efficiently.
        </p>
    </div>

    <div class="d-flex gap-2">

        <a href="/request/new" class="btn btn-dark">
            Request Asset
        </a>

        <a href="/assets/new" class="btn btn-primary">
            + Register Asset
        </a>

    </div>

</div>

    <!-- Dashboard Cards -->

    <div class="row">

        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow h-100">
                <div class="card-body text-center">

                    <div style="font-size:40px;">📦</div>

                    <h5 class="mt-3">Total Assets</h5>

                    <h2 class="fw-bold text-primary">
                        <%= assetCount %>
                    </h2>

                    <a href="/assets" class="btn btn-outline-primary btn-sm">
                        View Assets
                    </a>

                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow h-100">
                <div class="card-body text-center">

                    <div style="font-size:40px;">🏢</div>

                    <h5 class="mt-3">Departments</h5>

                    <h2 class="fw-bold text-success">
                        <%= departmentCount %>
                    </h2>

                    <a href="/departments" class="btn btn-outline-success btn-sm">
                        Manage
                    </a>

                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow h-100">
                <div class="card-body text-center">

                    <div style="font-size:40px;">📂</div>

                    <h5 class="mt-3">Categories</h5>

                    <h2 class="fw-bold text-warning">
                        <%= categoryCount %>
                    </h2>

                    <a href="/categories" class="btn btn-outline-warning btn-sm">
                        Manage
                    </a>

                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow h-100">
                <div class="card-body text-center">

                    <div style="font-size:40px;">🤝</div>

                    <h5 class="mt-3">Allocations</h5>

                    <h2 class="fw-bold text-danger">
                        <%= allocationCount %>
                    </h2>

                    <a href="/allocations" class="btn btn-outline-danger btn-sm">
                        View
                    </a>

                </div>
            </div>
        </div>

    </div>

    <hr class="my-5">

    

    <!-- Recent Assets -->

    <h3 class="mb-3">🕒 Recently Added Assets</h3>

    <div class="card shadow">

        <div class="card-body p-0">

            <table class="table table-hover mb-0">

                <thead class="table-dark">

                    <tr>
                        <th>Asset Name</th>
                        <th>Department</th>
                        <th>Status</th>
                    </tr>

                </thead>

                <tbody>

                    <% if(recentAssets.length > 0){ %>

                        <% recentAssets.forEach(asset => { %>

                            <tr>

                                <td><%= asset.assetName %></td>

                                <td><%= asset.department.name %></td>

                                <td>

                                    <% if(asset.status === "Available"){ %>

                                        <span class="badge bg-success">
                                            Available
                                        </span>

                                    <% } else { %>

                                        <span class="badge bg-danger">
                                            Allocated
                                        </span>

                                    <% } %>

                                </td>

                            </tr>

                        <% }) %>

                    <% } else { %>

                        <tr>

                            <td colspan="3" class="text-center py-4">

                                No Assets Found

                            </td>

                        </tr>

                    <% } %>

                </tbody>

            </table>

        </div>

    </div>

</div>