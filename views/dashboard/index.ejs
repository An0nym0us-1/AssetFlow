<% layout("/layouts/boilerplate") %>

    <div class="container mt-4">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>
                <h1 class="fw-bold">📊 AssetFlow Dashboard</h1>
                <p class="text-muted">
                    Manage assets, departments and categories efficiently.
                </p>
            </div>

            <a href="/assets/new" class="btn btn-primary">
                + Register Asset
            </a>

        </div>
        <div class="row">

            <div class="col-md-3 mb-4">
                <div class="card border-0 shadow h-100">
                    <div class="card-body text-center">

                        <div style="font-size:40px;">📦</div>

                        <h5 class="mt-3">Total Assets</h5>

                        <h2 class="fw-bold text-primary">
                            <%= assetCount %>
                        </h2>

                        <a href="/assets" class="btn btn-outline-primary btn-sm">
                            View Assets
                        </a>

                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card border-0 shadow h-100">
                    <div class="card-body text-center">

                        <div style="font-size:40px;">🏢</div>

                        <h5 class="mt-3">Departments</h5>

                        <h2 class="fw-bold text-success">
                            <%= departmentCount %>
                        </h2>

                        <a href="/departments" class="btn btn-outline-success btn-sm">
                            Manage
                        </a>

                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card border-0 shadow h-100">
                    <div class="card-body text-center">

                        <div style="font-size:40px;">📂</div>

                        <h5 class="mt-3">Categories</h5>

                        <h2 class="fw-bold text-warning">
                            <%= categoryCount %>
                        </h2>

                        <a href="/categories" class="btn btn-outline-warning btn-sm">
                            Manage
                        </a>

                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card border-0 shadow h-100">
                    <div class="card-body text-center">

                        <div style="font-size:40px;">🛠</div>

                        <h5 class="mt-3">Maintenance</h5>

                        <h2 class="fw-bold text-danger">
                            Coming Soon
                            </h2>

                            <button class="btn btn-outline-danger btn-sm" disabled>
                                Coming Soon
                            </button>

                    </div>
                </div>
            </div>

        </div>
    </div>